# Optional frontend overrides.
# Leave blank for local dev — defaults use http://localhost:3000.
# For unified production (same domain), leave blank — app uses relative /api paths.

# REST API base URL (include /api suffix)
# VITE_API_URL=https://your-backend.com/api

# Socket.IO server URL (no trailing slash)
# VITE_SOCKET_URL=https://your-backend.com

# Socket.IO path (default: /socket.io)
# VITE_SOCKET_PATH=/socket.io

# Force long-polling instead of WebSocket (useful behind some proxies)
# VITE_SOCKET_FORCE_POLLING=true

# PeerJS signaling server (no trailing slash)
# VITE_PEER_URL=https://your-backend.com

# PeerJS path (default: /peerjs)
# VITE_PEER_PATH=/peerjs
